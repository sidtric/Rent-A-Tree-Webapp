# Copy this file to `.env.local` and adjust as needed.
# `.env.local` overrides `.env` and is gitignored.

# Backend API URL the frontend talks to.
# - For local dev with your own backend running on :5000, use:
#     VITE_API_BASE=http://localhost:5000
# - To preview against live production data (hero images, trees, etc.), use:
#     VITE_API_BASE=https://rent-a-tree-backend.onrender.com
VITE_API_BASE=https://rent-a-tree-backend.onrender.com
